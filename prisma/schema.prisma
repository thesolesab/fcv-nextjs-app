generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id         BigInt   @id
  username   String?
  first_name String?
  last_name  String?
  position   String?
  phone      String?
  created_at DateTime @default(now())

  team_members  TeamMember[]
  registrations GameRegistration[]
  lineups       LineupPlayer[]

  @@map("users")
}

model Team {
  id                 String   @id @default(uuid())
  telegram_chat_id   BigInt   @unique
  name               String?
  created_at         DateTime @default(now())

  members            TeamMember[]
  games              Game[]
  schedules          TeamSchedule[]

  @@map("teams")
}

model TeamSchedule {
  id          String   @id @default(uuid())
  team_id     String
  day_of_week Int      // 0 (Воскресенье) - 6 (Суббота)
  time        String   // "HH:mm"
  location    String?
  created_at  DateTime @default(now())

  team        Team     @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@map("team_schedules")
}

enum Role {
  ADMIN
  COACH
  MEMBER
}

model TeamMember {
  id         String   @id @default(uuid())
  user_id    BigInt
  team_id    String
  role       Role     @default(MEMBER)
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  team       Team     @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@unique([user_id, team_id])
  @@map("team_members")
}

model Game {
  id                  String   @id @default(uuid())
  team_id             String
  date                DateTime
  location            String?
  description         String?
  telegram_message_id BigInt?
  created_at          DateTime @default(now())

  team          Team     @relation(fields: [team_id], references: [id], onDelete: Cascade)
  registrations GameRegistration[]
  lineups       GameLineup[]

  @@map("games")
}

enum RegistrationStatus {
  GOING
  NOT_GOING
  MAYBE
}

model GameRegistration {
  id          String   @id @default(uuid())
  game_id     String
  user_id     BigInt
  status      RegistrationStatus
  created_at  DateTime @default(now())

  game        Game     @relation(fields: [game_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([game_id, user_id])
  @@map("game_registrations")
}

model GameLineup {
  id         String   @id @default(uuid())
  game_id    String
  name       String   // e.g., "Команда А", "Красные"
  score      Int?     // Счет игры для этого состава
  created_at DateTime @default(now())

  game       Game     @relation(fields: [game_id], references: [id], onDelete: Cascade)
  players    LineupPlayer[]

  @@map("game_lineups")
}

model LineupPlayer {
  id         String   @id @default(uuid())
  lineup_id  String
  user_id    BigInt
  created_at DateTime @default(now())

  lineup     GameLineup @relation(fields: [lineup_id], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([lineup_id, user_id])
  @@map("lineup_players")
}

