generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id         BigInt   @id
  username   String?
  first_name String?
  last_name  String?
  created_at DateTime @default(now())

  @@map("users")
}

model Team {
  id                 String   @id @default(uuid())
  telegram_chat_id   BigInt   @unique
  name               String?
  created_at         DateTime @default(now())

  @@map("teams")
}
